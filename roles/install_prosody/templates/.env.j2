# vim:ft=env
### Prosody
# Domain on which user accounts will be created
VHOST="{{ vhost }}"
# Server operator credetials
USERNAME="{{ username }}"
PASSWORD="{{ password }}"
# Server operator
OPERATOR="${USERNAME}@${VHOST}"
# Toggle registration
ALLOW_REGISTRATION={{ allow_registration | lower }}
# Toggle invite only registration
INVITE_ONLY={{ invite_only | lower }}
# Ports on which Prosody will listen for XMPP over TLS client connections
C2S_XMPP_PORT={{ c2s_xmpp_port }}
# Ports on which Prosody will listen for XMPP over TLS server-to-server connections
S2S_XMPP_PORT={{ s2s_xmpp_port }}
# Ports on which builtin HTTP(s) server will listen
HTTP_SERVER_PORT={{ http_server_port }}
# Toggle server-to-server connections
S2S={{ s2s | lower }}
{% if welcome_message is defined and welcome_message %}
# Welcome message that is sent to new users
# Leave this variable empty or comment it out to disable
WELCOME_MESSAGE="{{ welcome_message }}"
{% else %}
# Welcome message that is sent to new users
# Leave this variable empty or comment it out to disable
#WELCOME_MESSAGE=""
{% endif %}
{% if registration_message is defined and registration_message %}
# Message that is sent to server operator when new user is registered
# Leave this variable empty or comment it out to disable
REGISTRATION_MESSAGE="{{ registration_message }}"
{% else %}
# Message that is sent to server operator when new user is registered
# Leave this variable empty or comment it out to disable
#REGISTRATION_MESSAGE=""
{% endif %}
{% if ansible_facts['default_ipv4']['address'] is defined and ansible_facts['default_ipv4']['address'] %}
# IPv4 address
IPV4_ADDRESS="{{ ansible_facts['default_ipv4']['address'] }}"
{% else %}
# IPv4 address
#IPV4_ADDRESS=""
{% endif %}
{% if ansible_facts['default_ipv6']['address'] is defined and ansible_facts['default_ipv6']['address'] %}
# IPv6 address
IPV6_ADDRESS="{{ ansible_facts['default_ipv6']['address'] }}"
{% else %}
# IPv6 address
#IPV6_ADDRESS=""
{% endif %}

{% if install_coturn | bool %}
### Coturn
# Coturn domain
# turn_external module disables itself if the variable is empty or commented out
TURN_HOST="{{ turn_host }}"
# Coturn port
TURN_PORT={{ turn_port }}
# Coturn secret
TURN_SECRET="{{ turn_secret }}"
{% else %}
### Coturn
# Coturn domain
# turn_external module disables itself if the variable is empty or commented out
#TURN_HOST="turn.example.com"
# Coturn port
#TURN_PORT=5349
# Coturn secret
#TURN_SECRET=""
{% endif %}

### Components
{% if muc_host is defined and muc_host %}
# Domain for muc (multi-user chat) module
# muc module disables itself if the variable is empty or commented out
MUC_HOST="{{ muc_host }}"
{% else %}
# Domain for muc (multi-user chat) module
# muc module disables itself if the variable is empty or commented out
#MUC_HOST="conference.example.com"
{% endif %}
{% if upload_host is defined and upload_host %}
# Domain for http_file_share module
# http_file_share module disables itself if the variable is empty or commented out
UPLOAD_HOST="{{ upload_host }}"
{% else %}
# Domain for http_file_share module
# http_file_share module disables itself if the variable is empty or commented out
#UPLOAD_HOST="share.example.com"
{% endif %}

### PostgreSQL
# Database name
POSTGRES_DB="{{ postgres_db }}"
# Database user
POSTGRES_USER="{{ postgres_user }}"
# Database password
POSTGRES_PASSWORD="{{ postgres_password }}"

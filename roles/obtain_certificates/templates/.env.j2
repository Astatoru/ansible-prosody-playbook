# vim:ft=env
### VirtualHost
# Domain on which user accounts will be created
VHOST="{{ vhost }}"

### Components
# Certbot won't obtain certificates for domains
# if their variable below is commented out
#
# In case you're editing current file manually
# Also uncomment or comment "-d VAR" inside compose.yaml
# or just use ansible playbook that does everything automatically
#
{% if muc_host is defined and muc_host %}
# Domain for muc (multi-user chat) module
MUC_HOST="{{ muc_host }}"
{% else %}
# Domain for muc (multi-user chat) module
#MUC_HOST="conference.example.com"
{% endif %}
{% if upload_host is defined and upload_host %}
# Domain for http_file_share module
UPLOAD_HOST="{{ upload_host }}"
{% else %}
# Domain for http_file_share module
#UPLOAD_HOST="share.example.com"
{% endif %}
{% if install_coturn | bool %}
# Coturn domain
TURN_HOST="{{ turn_host }}"
{% else %}
# Coturn domain
#TURN_HOST="turn.example.com"
{% endif %}
